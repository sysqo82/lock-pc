<Window x:Class="PCLockScreen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PCLockScreen"
        Title="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Title}"
        FlowDirection="{Binding Source={x:Static local:Loc.Instance}, Path=FlowDirection}"
        Height="600" Width="700"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Title}" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Account Section: first screen is register/login -->
        <GroupBox Grid.Row="1" Header="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Account}" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <!-- Logged-out view -->
                <StackPanel x:Name="LoggedOutPanel">
                    <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Email}"/>
                    <TextBox x:Name="EmailTextBox" Margin="0,5,0,10"/>

                    <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Password}"/>
                    <PasswordBox x:Name="AccountPasswordBox" Margin="0,5,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Login}" Click="Login_Click" Width="100" Height="30" Margin="0,0,10,0"/>
                        <Button Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Register}" Click="Register_Click" Width="100" Height="30"/>
                    </StackPanel>
                </StackPanel>

                <!-- Logged-in view -->
                <StackPanel x:Name="LoggedInPanel" Visibility="Collapsed">
                    <TextBlock>
                        <Run Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_LoggedInAs, Mode=OneWay}"/>
                        <Run x:Name="LoggedInEmailText" Text="" FontWeight="Bold"/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                        <Button Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_RefreshSchedule}" Click="RefreshSchedule_Click" Width="130" Height="30" Margin="0,0,10,0"/>
                        <Button Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Logout}" Click="Logout_Click" Width="100" Height="30"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Name="AccountStatusText"
                           Text=""
                           Foreground="Gray"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- App Settings -->
        <GroupBox Grid.Row="2" Header="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_AppSettings}" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <CheckBox x:Name="RunAtStartup" Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_RunAtStartup}" 
                          FlowDirection="LeftToRight"
                          HorizontalAlignment="Left"
                          Checked="RunAtStartup_Changed" Unchecked="RunAtStartup_Changed"/>
                <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_RunAtStartupHint}" 
                           FontSize="10" Foreground="Gray" Margin="20,2,0,0"/>

                <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_ScheduleNote}" Margin="0,10,0,5"/>
                <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_ScheduleNoteHint}"
                           FontSize="10" Foreground="Gray" Margin="0,0,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Language / שפה:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="LanguageCombo" Width="120" SelectionChanged="LanguageCombo_SelectionChanged">
                        <ComboBoxItem Tag="en" Content="English"/>
                        <ComboBoxItem Tag="he" Content="עברית"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Status Section -->
        <GroupBox Grid.Row="3" Header="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Status}" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <TextBlock x:Name="StatusText" Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_NotActive}" FontWeight="Bold"/>
                <TextBlock x:Name="TimeStatusText" Text="" Margin="0,5,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Control Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_ActivateLock}" Click="ActivateLock_Click"
                    Width="140" Height="35" Margin="0,0,10,0"/>
            <Button Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.Main_Exit}" Click="Exit_Click"
                    Width="140" Height="35"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
