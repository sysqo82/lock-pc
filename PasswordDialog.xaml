<Window x:Class="PCLockScreen.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PCLockScreen"
        Title="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.PassDlg_Title}"
        FlowDirection="{Binding Source={x:Static local:Loc.Instance}, Path=FlowDirection}" 
        Height="200" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.PassDlg_Title}" 
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.PassDlg_EnterPassword}" Margin="0,0,0,5"/>
        
        <PasswordBox Grid.Row="2" x:Name="PasswordInput" 
                     Margin="0,0,0,10"
                     KeyDown="PasswordInput_KeyDown"/>

        <TextBlock Grid.Row="3" x:Name="ErrorMessage" 
                   Text=""
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0,5,0,10"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.PassDlg_OK}" Click="OK_Click" Width="80" Height="30" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="{Binding Source={x:Static local:Loc.Instance}, Path=Strings.PassDlg_Cancel}" Click="Cancel_Click" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
